[user]
	email = corniedj@mail.uc.edu
	name = Derek Corniello
[init]
	defaultBranch = main
[core]
	editor = nvim
    pager = delta
[delta]
    side-by-side = true
    navigate = true
[alias]
    refresh = !git checkout main && fetch --all --prune
    sweep = !git branch --merged | grep -v '\\*' | grep -v 'main' | grep -v 'master' | xargs -r git branch -d
    last = log -1 HEAD
    tree = log --graph --all --pretty=format:'%C(yellow)%h%Creset -%C(auto)%d%Creset %s %C(green)(%cr) %C(bold blue)<%an>%Creset'
    oops = commit --amend --no-edit

    # Automatically detects main or master and updates it without checking it out
    refresh = "!f() { \
        bg=$(git rev-parse --verify --quiet main master | head -n 1); \
        if [ -n \"$bg\" ]; then \
            echo \"Updating local branch '$bg' in the background...\"; \
            git fetch --all --prune && git fetch origin \"$bg\":\"$bg\"; \
        else \
            echo \"Could not find main or master branch. Just fetching/pruning...\"; \
            git fetch --all --prune; \
        fi \
    }; f"

    # Automatically finds the closest parent/relative branch and diffs it
    review = "!f() { \
        parent=$(git show-branch --no-name --topo-order $(git branch --list | grep -v '^*' | sed 's/^[ *]*//') HEAD | grep '\\*' | grep -v \"\\[$(git branch --show-current)\\]\" | head -n1 | sed -E 's/^.*\\[([^\\]^~]+).*$/\\1/'); \
        if [ -n \"$parent\" ]; then \
            echo \"Comparing current branch to closest relative: $parent\"; \
            git diff \"$parent\"...HEAD; \
        else \
            echo \"No relative branch found. Defaulting to main/master.\"; \
            bg=$(git rev-parse --verify --quiet main master | head -n 1); \
            git diff \"$bg\"...HEAD; \
        fi \
    }; f"
[safe]
	directory = /mnt/usb/github-backups/*
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[pull]
	ff = only
[credential]
	helper = /usr/lib/git-core/git-credential-libsecret
